<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:padding="24dp">

    <!-- Ikon tengkorak -->
    <TextView
        android:id="@+id/tv_skull"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        android:text="☠"
        android:textSize="72sp"
        android:textColor="#FF0000"
        android:textAlignment="center"/>

    <!-- Judul ancaman utama -->
    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="⚠ YOUR DEVICE HAS BEEN ENCRYPTED ⚠"
        android:textColor="#FF0000"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textAlignment="center"/>

    <!-- Subtitle -->
    <TextView
        android:id="@+id/tv_subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="All your files have been locked by CryptoVirus v3.1"
        android:textColor="#AAAAAA"
        android:textSize="13sp"
        android:textAlignment="center"/>

    <!-- Progress bar enkripsi palsu -->
    <ProgressBar
        android:id="@+id/progress_bar"
        style="@android:style/Widget.ProgressBar.Horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:max="100"
        android:progress="0"
        android:progressTint="#FF0000"
        android:progressBackgroundTint="#330000"/>

    <!-- Label progress persen -->
    <TextView
        android:id="@+id/tv_progress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Encrypting files... 0%"
        android:textColor="#FF4444"
        android:textSize="14sp"
        android:textStyle="bold"/>

    <!-- Nama file yang sedang "dienkripsi" -->
    <TextView
        android:id="@+id/tv_current_file"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text=""
        android:textColor="#666666"
        android:textSize="11sp"
        android:textAlignment="center"
        android:singleLine="true"/>

    <!-- Jumlah file terenkripsi -->
    <TextView
        android:id="@+id/tv_file_count"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Files encrypted: 0"
        android:textColor="#FF6666"
        android:textSize="15sp"
        android:textStyle="bold"/>

    <!-- Hitung mundur -->
    <TextView
        android:id="@+id/tv_countdown"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="00:01:00"
        android:textColor="#FF0000"
        android:textSize="48sp"
        android:textStyle="bold"
        android:fontFamily="monospace"
        android:textAlignment="center"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Time remaining before permanent data loss"
        android:textColor="#FF4444"
        android:textSize="11sp"
        android:textAlignment="center"/>

    <!-- Alamat Bitcoin palsu -->
    <TextView
        android:id="@+id/tv_btc"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Send 0.5 BTC to:\n1F1tAaz5x1HUXrCN‌LbtMDqcw6o5GNn4xqX"
        android:textColor="#FFD700"
        android:textSize="12sp"
        android:textAlignment="center"
        android:fontFamily="monospace"
        android:background="#1A1A00"
        android:padding="10dp"/>

    <!-- Peringatan bawah -->
    <TextView
        android:id="@+id/tv_warning"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="⛔ DO NOT restart your phone\n⛔ DO NOT remove your SIM card\n⛔ DO NOT contact authorities"
        android:textColor="#FF3333"
        android:textSize="12sp"
        android:textAlignment="center"
        android:lineSpacingExtra="4dp"/>

    <!-- Teks April Mop (tersembunyi awalnya) -->
    <TextView
        android:id="@+id/tv_april_mop"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="😂 YAHAHAH APRIL MOP! 😂\n\nTenang... HP kamu aman kok! 😜"
        android:textColor="#00FF00"
        android:textSize="36sp"
        android:textStyle="bold"
        android:textAlignment="center"
        android:visibility="gone"/>

</LinearLayout>
