<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:fillViewport="true"
    android:scrollbars="none">

<LinearLayout
    android:id="@+id/root_layout"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#000000"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:paddingLeft="20dp"
    android:paddingRight="20dp"
    android:paddingTop="10dp"
    android:paddingBottom="16dp">

    <!-- Tengkorak -->
    <TextView
        android:id="@+id/tv_skull"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="☠️"
        android:textSize="48sp"
        android:textColor="#FF0000"
        android:textAlignment="center"/>

    <!-- Judul ancaman -->
    <TextView
        android:id="@+id/tv_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="⚠ YOUR DEVICE HAS BEEN ENCRYPTED ⚠"
        android:textColor="#FF0000"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textAlignment="center"/>

    <TextView
        android:id="@+id/tv_subtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="CryptoVirus v3.1 — Advanced Persistent Threat"
        android:textColor="#888888"
        android:textSize="10sp"
        android:textAlignment="center"/>

    <!-- KAMERA ASLI (preview kecil dari front camera) -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:layout_marginTop="8dp"
        android:background="#110000">

        <TextureView
            android:id="@+id/camera_preview"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:alpha="0.7"/>

        <TextView
            android:id="@+id/tv_camera"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="top"
            android:background="#88000000"
            android:text="📸 FRONT CAMERA ACTIVE — RECORDING..."
            android:textColor="#FF0044"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textAlignment="center"
            android:padding="3dp"/>

        <TextView
            android:id="@+id/tv_rec"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:text="● REC"
            android:textColor="#FF0000"
            android:textSize="12sp"
            android:textStyle="bold"
            android:padding="4dp"/>
    </FrameLayout>

    <!-- Device info ASLI -->
    <TextView
        android:id="@+id/tv_device_info"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text=""
        android:textColor="#FF6600"
        android:textSize="9sp"
        android:fontFamily="monospace"
        android:textAlignment="center"
        android:background="#1A0A00"
        android:padding="6dp"/>

    <!-- Progress bar enkripsi -->
    <ProgressBar
        android:id="@+id/progress_bar"
        style="@android:style/Widget.ProgressBar.Horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:max="100"
        android:progress="0"
        android:progressTint="#FF0000"
        android:progressBackgroundTint="#330000"/>

    <TextView
        android:id="@+id/tv_progress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="1dp"
        android:text="Encrypting files... 0%"
        android:textColor="#FF4444"
        android:textSize="12sp"
        android:textStyle="bold"/>

    <TextView
        android:id="@+id/tv_current_file"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="#555555"
        android:textSize="9sp"
        android:textAlignment="center"
        android:singleLine="true"
        android:fontFamily="monospace"/>

    <TextView
        android:id="@+id/tv_file_count"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Files encrypted: 0 | Contacts stolen: 0"
        android:textColor="#FF6666"
        android:textSize="11sp"
        android:textStyle="bold"/>

    <!-- Aksi destruktif log -->
    <TextView
        android:id="@+id/tv_destructive"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text=""
        android:textColor="#FF0000"
        android:textSize="9sp"
        android:textStyle="bold"
        android:fontFamily="monospace"
        android:lineSpacingExtra="1dp"/>

    <!-- Hitung mundur -->
    <TextView
        android:id="@+id/tv_countdown"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="00:01:00"
        android:textColor="#FF0000"
        android:textSize="46sp"
        android:textStyle="bold"
        android:fontFamily="monospace"
        android:textAlignment="center"/>

    <TextView
        android:id="@+id/tv_countdown_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="⏱ TIME UNTIL PERMANENT DATA DESTRUCTION"
        android:textColor="#FF4444"
        android:textSize="9sp"
        android:textStyle="bold"
        android:textAlignment="center"/>

    <!-- Bitcoin palsu -->
    <TextView
        android:id="@+id/tv_btc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="💰 Send 0.5 BTC to restore:\nbc1qxy2kgdygjrsqtzq2n0yrf2493p83kkfjhx0wlh\n⚠ Must be received before timer expires"
        android:textColor="#FFD700"
        android:textSize="10sp"
        android:textAlignment="center"
        android:fontFamily="monospace"
        android:background="#1A1A00"
        android:padding="6dp"/>

    <!-- Peringatan -->
    <TextView
        android:id="@+id/tv_warning"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="⛔ DO NOT restart — encryption will corrupt\n⛔ DO NOT remove SIM — location tracked\n⛔ DO NOT contact authorities — we have your data\n⛔ DO NOT screenshot — screen is monitored"
        android:textColor="#FF3333"
        android:textSize="9sp"
        android:textAlignment="center"
        android:lineSpacingExtra="2dp"/>

    <!-- April Mop (tersembunyi) -->
    <TextView
        android:id="@+id/tv_april_mop"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:text="😂🤣😂\n\nYAHAHAH\nAPRIL MOP!\n\nTenang... HP kamu aman kok!\nSemua tadi itu BOHONG 😜\n\n🎉 Pranked! 🎉"
        android:textColor="#00FF00"
        android:textSize="30sp"
        android:textStyle="bold"
        android:textAlignment="center"
        android:visibility="gone"
        android:lineSpacingExtra="4dp"/>

</LinearLayout>
</ScrollView>
